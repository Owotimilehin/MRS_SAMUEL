# Customer storefront — env. Vite exposes only VITE_* vars to the browser;
# PUBLIC_* vars are read at runtime by the SSR Node server (server functions),
# never sent to the client. Copy to `.env` and fill in.

# --- API base (used by server functions that proxy /v1/public/* to the API) ---
# Preferred: runtime env on the SSR Node server, so ONE built image is portable.
#   - in the compose network:  http://api:3001
#   - local dev:               http://localhost:3001
PUBLIC_API_URL=http://localhost:3001
# Build-time fallback (Vite inlines this) if PUBLIC_API_URL is unset at runtime.
VITE_API_URL=http://localhost:3001

# Mapbox public token — powers checkout address autocomplete + map preview.
# Create at https://account.mapbox.com/access-tokens (free tier ~100k req/mo).
# Restrict it by URL (your domain + http://localhost:3002 for local dev).
# Leaving it blank is safe: the address field falls back to a plain textarea.
VITE_MAPBOX_TOKEN=

# Cloudflare Turnstile site key — checkout/contact bot-protection widget. Public
# (safe to expose). Blank = no widget shown and no bot check (fail-open; the API
# also fails open when its TURNSTILE_SECRET is unset).
VITE_TURNSTILE_SITEKEY=
