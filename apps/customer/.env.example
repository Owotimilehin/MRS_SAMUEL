# Customer storefront — Vite env (client-side; only VITE_* vars are exposed).
# Copy to `.env` and fill in. Leaving VITE_MAPBOX_TOKEN blank is safe: the
# checkout address field falls back to a plain textarea.

# Mapbox public token — powers checkout address autocomplete + map preview.
# Create at https://account.mapbox.com/access-tokens (free tier ~100k req/mo).
# Restrict it by URL (your domain + http://localhost:3002 for local dev).
VITE_MAPBOX_TOKEN=
