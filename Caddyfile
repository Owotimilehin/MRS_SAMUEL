# Caddy terminates HTTPS and routes per subdomain. Let's Encrypt certs are
# obtained on first start; renewed automatically every ~60 days.
#
# If you front this with Cloudflare in "Full (strict)" proxy mode:
#   - Cloudflare must DNS-only (grey cloud) during the first cert issuance,
#     OR replace these blocks with Cloudflare Origin Certificates (see below).
#   - Once the cert exists, flip Cloudflare back to proxied (orange cloud).
#
# Alternative: drop a Cloudflare Origin Certificate (15-year validity) and
# point `tls /etc/caddy/origin.crt /etc/caddy/origin.key` instead of relying
# on Let's Encrypt.

{
	# Email used by Let's Encrypt for renewal notifications
	email ops@mrssamueljuice.com
}

# ─────────── Customer site ───────────
www.mrssamueljuice.com, mrssamueljuice.com {
	encode zstd gzip
	reverse_proxy customer:80 {
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ─────────── Admin app ───────────
admin.mrssamueljuice.com {
	encode zstd gzip
	reverse_proxy admin:80 {
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}
}

# ─────────── API ───────────
# Customer + admin call their own origin's /v1/* (proxied inside the static
# containers' nginx). This api. host exists for webhooks (Payaza, Bolt) and
# for ad-hoc curl / debugging.
api.mrssamueljuice.com {
	encode zstd gzip
	reverse_proxy api:3001 {
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}
}
