NODE_ENV=development
DATABASE_URL=postgres://ms:ms@localhost:5432/ms_dev
DATABASE_URL_REPLICA=postgres://ms:ms@localhost:5432/ms_dev
REDIS_URL=redis://localhost:6379
JWT_SIGNING_KEY=dev-only-not-for-production-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_SIGNING_KEY_PREVIOUS=
SESSION_COOKIE_NAME=ms_session
SENTRY_DSN=
LOG_LEVEL=debug
PUBLIC_API_URL=http://localhost:3001
PUBLIC_ADMIN_URL=http://localhost:3000
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# OPay Cashier (primary online payment provider) — from your merchant dashboard.
# Set these on the API and worker services. The active provider is owner-
# toggleable in admin Settings; it defaults to OPay.
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
# The merchant secret/private key. Used to HMAC-SHA512 sign the cashier/status
# query + verify callbacks. Read as OPAY_SECRET_KEY by the API.
OPAY_SECRET_KEY=
# Optional: override the API base. Defaults to https://liveapi.opaycheckout.com
# (production). Use https://testapi.opaycheckout.com for sandbox.
OPAY_API_BASE=
