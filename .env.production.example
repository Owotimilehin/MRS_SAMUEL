# ─────────────────────────────────────────────────────────────────────────────
# Production env. Copy to .env.production, fill in real values, never commit.
# Used by `docker compose --env-file .env.production -f docker-compose.yml \
#                        -f docker-compose.prod.yml up -d`
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (the prod DB user/password — pick something long) ───────────────
POSTGRES_USER=ms
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_STRING
POSTGRES_DB=ms_prod
DATABASE_URL=postgres://ms:REPLACE_WITH_LONG_RANDOM_STRING@postgres:5432/ms_prod

# ── App secrets ──────────────────────────────────────────────────────────────
# 32+ char random. Generate: openssl rand -hex 32
JWT_SIGNING_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_SIGNING_KEY_PREVIOUS=

# ── Public URLs (what the browser sees) ──────────────────────────────────────
PUBLIC_API_URL=https://api.mrssamueljuice.com
PUBLIC_ADMIN_URL=https://admin.mrssamueljuice.com
PUBLIC_CUSTOMER_URL=https://www.mrssamueljuice.com

# ── Payaza (NGN payments) ────────────────────────────────────────────────────
# From your Payaza dashboard. Webhook URL to register there:
#   https://api.mrssamueljuice.com/v1/webhooks/payaza
PAYAZA_SECRET_KEY=
PAYAZA_WEBHOOK_SECRET=
# Leave default unless Payaza tells you otherwise
PAYAZA_API_BASE=https://api.payaza.africa/v1

# ── Bolt Send (delivery) ─────────────────────────────────────────────────────
# Set BOLT_PROVIDER=mock to keep the mock running in prod (e.g. soft launch).
# Webhook URL to register with Bolt:
#   https://api.mrssamueljuice.com/v1/webhooks/bolt
BOLT_PROVIDER=live
BOLT_API_KEY=
BOLT_WEBHOOK_SECRET=
BOLT_API_BASE=https://api.bolt.eu

# ── Telegram (ops alerts) ────────────────────────────────────────────────────
# Optional. Create a bot via @BotFather, then add it to each channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT=
TELEGRAM_BRANCH_AJAO_CHAT=
TELEGRAM_FACTORY_CHAT=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Mrs. Samuel <noreply@mrssamueljuice.com>

# ── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=

# ── Cloudflare R2 (for backup.sh) ────────────────────────────────────────────
# Create an R2 bucket called "ms-backups" and an R2 API token. Configured via
# `rclone config` on the host, not via env. See DEPLOY.md.
