# Copy to .env on the VPS, fill in real values, NEVER commit.
#
# Picked up automatically by `docker compose up -d`.

# Bind published ports to localhost only — Cloudflare Tunnel is the only ingress.
HOST_BIND=127.0.0.1

# Postgres
POSTGRES_USER=ms
POSTGRES_PASSWORD=                  # openssl rand -hex 24
POSTGRES_DB=ms_prod
DATABASE_URL=postgres://ms:THE_SAME_PASSWORD@postgres:5432/ms_prod

# App
JWT_SIGNING_KEY=                    # openssl rand -hex 32 (32+ chars)
PUBLIC_API_URL=https://api.mrssamuel.com
PUBLIC_ADMIN_URL=https://admin.mrssamuel.com
PUBLIC_CUSTOMER_URL=https://www.mrssamuel.com

# Payaza collection — from your Payaza dashboard (Settings → API Keys & Webhooks).
# Register the callback/webhook URL: https://api.mrssamuel.com/v1/webhooks/payaza
# Empty PAYAZA_PUBLIC_KEY = mock mode. Use live PZ78-PKLIVE-/SKLIVE- keys in prod.
# NOTE: Payaza does NOT sign callbacks — there is no webhook secret. The callback
# is a wake-up; payment is re-verified server-to-server by order reference.
PAYAZA_SECRET_KEY=
PAYAZA_PUBLIC_KEY=
PAYAZA_API_BASE=https://api.payaza.africa/live
# Optional: bearer if the live smoke test 401s (default payaza-base64).
PAYAZA_AUTH_SCHEME=

# OPay Cashier — PRIMARY online payment provider (server redirect). From your
# OPay merchant dashboard. Register the callback URL:
#   https://api.mrssamuel.com/v1/webhooks/opay
# The active provider is owner-toggleable in admin Settings (defaults to OPay).
# OPAY_MERCHANT_ID is the numeric MerchantId (e.g. 256626070286780), NOT the
# merchant display name. Keys are OPAYPUB… (public) / OPAYPRV… (secret).
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_SECRET_KEY=
# Base defaults to https://liveapi.opaycheckout.com (production).
# Use https://testapi.opaycheckout.com for sandbox.
OPAY_API_BASE=https://liveapi.opaycheckout.com

# Shipbubble (Nigerian courier aggregator) — the only delivery provider.
# SHIPBUBBLE_PROVIDER=live uses the real API; anything else uses the built-in
# mock (dev/CI). The API key is sandbox until you generate a live key. Fees are
# debited from a PREPAID WALLET — keep it funded or label creation fails.
SHIPBUBBLE_PROVIDER=live
SHIPBUBBLE_API_KEY=
SHIPBUBBLE_API_BASE=https://api.shipbubble.com/v1
SHIPBUBBLE_WEBHOOK_SECRET=
# Default sender (pickup) branch + juice carton package profile for rate calls.
SHIPBUBBLE_SENDER_NAME=Mrs Samuel Fruit Juice
SHIPBUBBLE_SENDER_PHONE=
SHIPBUBBLE_SENDER_EMAIL=info@mrssamuel.com
SHIPBUBBLE_SENDER_ADDRESS=Ajao Estate, Lagos, Nigeria
SHIPBUBBLE_CATEGORY_ID=2178251
SHIPBUBBLE_PKG_WEIGHT_KG=1.5
SHIPBUBBLE_PKG_VALUE_NGN=6000
SHIPBUBBLE_PKG_LENGTH_CM=25
SHIPBUBBLE_PKG_WIDTH_CM=20
SHIPBUBBLE_PKG_HEIGHT_CM=15

# Cloudflare Turnstile (checkout bot protection). Server-side verify is fail-open:
# blank = feature off, checkout works. ⚠️ DO NOT set TURNSTILE_SECRET until the
# customer CHECKOUT actually renders a Turnstile widget and sends turnstile_token
# — it currently does NOT (only the contact form does). Setting the secret without
# the checkout widget makes EVERY order fail with "Bot check failed". Leave blank.
TURNSTILE_SECRET=

# Frontend build args. NOTE: VITE_TURNSTILE_SITEKEY is not yet wired into the
# customer Dockerfile/build, and no checkout code reads it — wiring the checkout
# widget is a prerequisite before TURNSTILE_SECRET above can be safely set.
VITE_TURNSTILE_SITEKEY=
VITE_MAPBOX_TOKEN=

# Optional but recommended
# Resend transactional email. RESEND_FROM must be on a domain verified in
# Resend (mrssamuel.com). RESEND_REPLY_TO is where customer replies land —
# the live Cloudflare-routed business inbox.
RESEND_API_KEY=
RESEND_FROM=Mrs. Samuel <orders@mrssamuel.com>
RESEND_REPLY_TO=info@mrssamuel.com
SENTRY_DSN=

# Telegram order alerts (worker → t.me/MrssamueljuiceBot)
# 1. Talk to @BotFather → /newbot → copy the HTTP API token → paste below
# 2. Add the bot as an admin to each channel (owner / factory / branch)
# 3. Get each channel's numeric chat id (starts with -100…):
#      curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    or use @userinfobot inside the channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHANNEL_ID=
TELEGRAM_FACTORY_CHANNEL_ID=
TELEGRAM_BRANCH_AJAO_CHANNEL_ID=
